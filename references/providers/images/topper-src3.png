const options = {
  activityTracking: {
    heartbeatDelay: 10,
    minimumVisitLength: 30
  },	
  cookieSameSite: 'Lax',
  appId: IS_DEVELOPMENT ? 'development_topperpay_website' : 'production_topperpay_website',
  collectorUrl: IS_DEVELOPMENT ? 'http://com-uphold-qa1.collector.snplow.net' : 'https://telemetry.uphold.com',
  contexts: {
    browser: true,
    session: true,
    webPage: true
  },
  cookieDomain: IS_DEVELOPMENT ? 'topper-website-staging.webflow' : 'topperpay.com',
  stateStorageStrategy: 'localStorage',
  trackPageView: true
};

window.snowplow('newTracker', 'topperTracker', options.collectorUrl, options);
window.snowplow('trackPageView');
</script>

