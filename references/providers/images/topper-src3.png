</svg></div></a><div class="text-size-small text-color-neutral-100">Stay up-to-date with our latest news and announcements. Get access to our press releases, news articles, and other media content.</div></div><div class="navbar_subnav-item"><a id="blog-link" href="/en-gb/blog" class="navbar_subnav-item-header w-inline-block"><div>Blog</div><div class="icon-24 w-embed"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path fill-rule="evenodd" clip-rule="evenodd" d="M14.0303 4.71967C13.7374 4.42678 13.2626 4.42678 12.9697 4.71967C12.6768 5.01256 12.6768 5.48744 12.9697 5.78033L18.4393 11.25H3.75C3.33579 11.25 3 11.5858 3 12C3 12.4142 3.33579 12.75 3.75 12.75H18.4393L12.9697 18.2197C12.6768 18.5126 12.6768 18.9874 12.9697 19.2803C13.2626 19.5732 13.7374 19.5732 14.0303 19.2803L20.7803 12.5303C20.9268 12.3839 21 12.1919 21 12C21 11.8983 20.9798 11.8013 20.9431 11.7129C20.9065 11.6245 20.8522 11.5416 20.7803 11.4697L14.0303 4.71967Z" fill="currentColor"/>
</svg></div></a><div class="text-size-small text-color-neutral-100">Inside Topper: exclusive articles and in-depth analysis</div></div><div class="navbar_subnav-item"><a id="blog-link" href="https://topperpay.design/" target="_blank" class="navbar_subnav-item-header w-inline-block"><div>Brand Guidelines</div><div class="icon-24 w-embed"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path fill-rule="evenodd" clip-rule="evenodd" d="M14.0303 4.71967C13.7374 4.42678 13.2626 4.42678 12.9697 4.71967C12.6768 5.01256 12.6768 5.48744 12.9697 5.78033L18.4393 11.25H3.75C3.33579 11.25 3 11.5858 3 12C3 12.4142 3.33579 12.75 3.75 12.75H18.4393L12.9697 18.2197C12.6768 18.5126 12.6768 18.9874 12.9697 19.2803C13.2626 19.5732 13.7374 19.5732 14.0303 19.2803L20.7803 12.5303C20.9268 12.3839 21 12.1919 21 12C21 11.8983 20.9798 11.8013 20.9431 11.7129C20.9065 11.6245 20.8522 11.5416 20.7803 11.4697L14.0303 4.71967Z" fill="currentColor"/>
</svg></div></a><div class="text-size-small text-color-neutral-100">Get access to Topper brand assets and learn our guidelines.</div></div></div></div><div class="script w-embed w-script"><script>
  //get the slug from url and check if its equals to "news", "about" or "blog" and make it active
  const slug = window.location.pathname.split("/")[1];
  
  const companyLink = document.getElementById("company-link");
  const blogLink = document.getElementById("blog-link");
  const blogLinkMobile = document.getElementById("blog-link-mobile");
 
   setTimeout(() => {
    if (slug === "blog" && blogLink) {
      blogLink.classList.add("w--current");
      blogLinkMobile.classList.add("w--current");
    } else {
      blogLink.classList.remove("w--current");
      blogLinkMobile.classList.remove("w--current");
    }
  }, 500);

  if (slug === "news" && companyLink || slug === "about" && companyLink) {
   	companyLink.classList.add("w--current");
  } else {
		if (companyLink) companyLink.classList.remove("w--current");
  }
