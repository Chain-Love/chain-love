</svg></div><div class="icon-24 z-index-2 button-arrow w-embed"><svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none"><path fill="currentColor" fill-rule="evenodd" d="M14.03 4.72a.75.75 0 1 0-1.06 1.06l5.47 5.47H3.75a.75.75 0 0 0 0 1.5h14.69l-5.47 5.47a.75.75 0 1 0 1.06 1.06l6.75-6.75a.747.747 0 0 0 0-1.06l-6.75-6.75Z" clip-rule="evenodd"/></svg></div></div></footer><div id="w-node-e5f75590-0603-dfbe-8b3e-8736707e9141-707e9141" class="mobile_cta"><a href="#" class="button is-icon get-started-button mobile-full-width w-inline-block"><div class="button_text">Buy or Sell Crypto</div><div class="icon-24 z-index-2 w-embed"><svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none"><path fill="currentColor" fill-rule="evenodd" d="M14.03 4.72a.75.75 0 1 0-1.06 1.06l5.47 5.47H3.75a.75.75 0 0 0 0 1.5h14.69l-5.47 5.47a.75.75 0 1 0 1.06 1.06l6.75-6.75a.747.747 0 0 0 0-1.06l-6.75-6.75Z" clip-rule="evenodd"/></svg></div></a></div></div><script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=63a5d5c7760c9d1c97ca0efc" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/63a5d5c7760c9d1c97ca0efc/js/webflow.schunk.f2efb3c5440a81cf.js" type="text/javascript" integrity="sha384-VK02VJvMib7ytrF5M2joPWNtDQs366FZgEQ5B+Iwnjx0WBnwQXfootyziSYxdrmS" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/63a5d5c7760c9d1c97ca0efc/js/webflow.schunk.6ad079800b1ffa44.js" type="text/javascript" integrity="sha384-dKDr7As96l/rO/b6XsBiMI5GS8sxZy3SnBMUhdDGQE6MycdFQN9vTPh8/QaHLyQx" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/63a5d5c7760c9d1c97ca0efc/js/webflow.d2fa460e.67a9b2f39172fe8a.js" type="text/javascript" integrity="sha384-sayS/9d7U/sdCPuYyr0YKu1ZmjEgS9SWvHz/VsRPzVKJHNkLQXOJ5U0wCpBDilLM" crossorigin="anonymous"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.3/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.3/ScrollTrigger.min.js"></script>

<script>
  // Get Utm Parameters from url
  function getUtmParameters() {
    const urlParams = new URLSearchParams(window.location.search);
    const utmParams = {};
    const utmKeys = [
      'utm_source',
      'utm_medium',
      'utm_campaign',
      'utm_term',
      'utm_content',
      'gclid',
      'fbclid',
    ];

    utmKeys.forEach((key) => {
      if (urlParams.has(key)) {
        utmParams[key] = urlParams.get(key);
      }
    });

    return utmParams;
  }
  const utmParameters = getUtmParameters();
  console.log('utmParameters: ', utmParameters);
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Navbar
    const navbar = document.getElementById('navbar');
    const fcaBanner = document.querySelector('.section_banners');

    window.addEventListener('scroll', () => {
      if (window.pageYOffset > 100) {
        navbar.classList.add('is-scrolled');
        
        if (fcaBanner.children.length > 0) {
          fcaBanner.classList.add('is-scrolled');
        }
      } else {
        navbar.classList.remove('is-scrolled');
        
        if (fcaBanner.children.length > 0) {
          fcaBanner.classList.remove('is-scrolled');
        }
      }
    });

    // Scroll top on load
    if (history.scrollRestoration) {
      history.scrollRestoration = 'manual';
    }

    // Get current year
    document.querySelectorAll('.current-year').forEach(element => {
      element.textContent = new Date().getFullYear();
    });

    // Remove en-GB language switcher item
    const enGbSelector = document.querySelector('.lang-switcher_item.w-locales-item[locale="en-GB"]');
    if (enGbSelector) {
      enGbSelector.remove();
    }

    // Remove language switcher if current locale is en-GB
    const currentLocale = document.documentElement.lang || 'en';
    if (currentLocale === 'en-GB') {
      const langSwitcher = document.querySelector('[data-lang-switcher]');
      if (langSwitcher) {
        langSwitcher.remove();
      }
    }
  });

  // Footer CTA visibility based on scroll
  const footer = document.querySelector('.footer');
  
  if (footer && typeof ScrollTrigger !== 'undefined') {
    ScrollTrigger.create({
      trigger: footer,
      onUpdate: updateFooterCta,
    });

    function updateFooterCta() {
      const mobileCta = document.querySelector('.mobile_cta');
      
      if (ScrollTrigger.isInViewport(footer) && mobileCta) {
        mobileCta.style.display = 'none';
      } else {
        mobileCta.style.display = 'block';
      }
    }
  }
</script>

<script>
  function displayErrorToast() {
    document.querySelector('.error-toast-wrapper').classList.add('display');
    setTimeout(() => {
      document.querySelector('.error-toast').classList.add('display');
    }, 100);
  }

  const spinner = document.querySelector('.loading-spinner');
  const arrow = document.querySelector('.button-arrow');
  const allButtons = document.querySelectorAll('.button');

  const buttonTexts = [
    'Buy or Sell Crypto',
    'Compre ou Venda Cripto',
    'Buy Crypto',
    'Comprar Cripto',
    'Start Buying Crypto',
    'Comece a Comprar Cripto',
    'Empezar a Comprar Cripto',
    'Comienza a Comprar Cripto',
    'Comprar o Vender Cripto',
  ];

  const setButtonLoadingState = (button, isLoading) => {
    const buttonText = button.querySelector('.button_text');
    const embed = button.querySelector('.w-embed');

    let currentText = buttonText.innerText;

    if (isLoading) {
      buttonText.innerText = resolveTranslation('Redirecting...', 'Redirecionando...', 'Redirigiendo...');
      embed.innerHTML = '';
      embed.appendChild(spinner);
    } else {
      buttonText.innerText = currentText;

      embed.innerHTML = '';
      embed.appendChild(arrow);
    }
  };

  const handleButtonClick = async (button) => {
    setButtonLoadingState(button, true);

    try {
      const utmParameters = getUtmParameters();
      const utmQueryString = Object.keys(utmParameters)
            .map(key => `${key}=${utmParameters[key]}`)
            .join('&');
      const baseUrl = `${widgetApiEndpoint}/open-widget/multiple?widgetIds=${widgetsIds[0]}&widgetIds=${widgetsIds[1]}&locale=${widgetCurrentLocale}`;
      const finalFetchUrl = baseUrl + (utmQueryString ? `&${utmQueryString}` : '');
      
      const response = await fetch(
        finalFetchUrl,
        { method: 'POST' }
      );

      const data = await response.json();
      
      if (data.url) {
        const redirectUrl = new URL(data.url, window.location.href);
        
        Object.keys(utmParameters).forEach(key => {
            redirectUrl.searchParams.set(key, utmParameters[key]);
        });
        
        window.location.href = redirectUrl.toString();
        //window.location.href = data.url;
      } else {
        displayErrorToast();
        setButtonLoadingState(button, false);
      }
    } catch (error) {
      displayErrorToast();
      setButtonLoadingState(button, false);
    }
  };

  allButtons.forEach((button) => {
    if (buttonTexts.includes(button.textContent)) {
      button.addEventListener('click', () => {
        setTimeout(() => handleButtonClick(button), 500);
      });
    }
  });
</script>

<script>
  // Fix editor fonts sizes
  document.addEventListener('DOMContentLoaded', function () {
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.type === 'attributes') {
          const varsClass = document.body.getAttribute('data-wf-unified-tokens');

          if (!varsClass) return;

          const classElements = document.querySelectorAll(`.${varsClass}`);

          classElements.forEach((classElement) => {
            if (!classElement) return;

            classElement.style.cssText = `
            --typography-font-size-body-large: 1.6rem;
            --typography-line-height-body-large: --typography-font-size-body-large;
    
            --wf-system---typography-font-size-title: 1.6rem;
            --wf-system---typography-line-height-title: --wf-system---typography-font-size-title;
    
            --wf-system---typography-font-size-body: 1.4rem;
            --wf-system---typography-line-height-body: --wf-system---typography-font-size-body;
            
            --wf-system---typography-font-size-heading: 1.4rem;
            --wf-system---typography-line-height-heading: --wf-system---typography-font-size-heading;
          `;
          });
        }
      });
    });

    observer.observe(document.body, {
      attributes: true,
      attributeFilter: ['data-wf-unified-tokens'],
    });
  });
</script>


<script>
document.addEventListener("DOMContentLoaded", function () {
  /*
  * Home Banners Component
  */
  
  // Remove banner if has no items
  const bannerWrapper = document.querySelector(".home_banners");
  //const bannersList = document.querySelector(".swiper-wrapper.home-banners");
  const bannersList = document.querySelector(".swiper.home-banners .swiper-wrapper");

  /*if ((!bannersList || !bannersList.children.length) && bannerWrapper) {
    bannerWrapper.remove();
    return;
  }*/

  const baseOptions = {
    speed: 1000,
    autoplay: {
      delay: 6000,
      disableOnInteraction: false,
    },
    loop: true,
  };

  const mobileOptions = {
    ...baseOptions,
    effect: "fade",
    fadeEffect: {
      crossFade: true
    }
  };

	// initialize Swiper based on breakpoint
  let isDesktop = window.innerWidth >= 768;
  let bannersSwiper = new Swiper(".swiper.home-banners", isDesktop ? baseOptions : mobileOptions);

  /*function updateSwiperConfig() {
    const windowWidth = window.innerWidth;
    // Check if the window width crosses the 768px threshold
    if ((windowWidth >= 768 && !isDesktop) || (windowWidth < 768 && isDesktop)) {
      isDesktop = windowWidth >= 768;
      bannersSwiper.destroy();
      
      const newSwiperConfig = isDesktop ? baseOptions : mobileOptions;
      bannersSwiper = new Swiper(".swiper.home-banners", newSwiperConfig);
    }
  }*/
  
  function updateSwiperConfig() {
    const windowWidth = window.innerWidth;
    if ((windowWidth >= 768 && !isDesktop) || (windowWidth < 768 && isDesktop)) {
      isDesktop = windowWidth >= 768;
      bannersSwiper.destroy(true, true);
      bannersSwiper = new Swiper(".swiper.home-banners", isDesktop ? baseOptions : mobileOptions);
    }
  }


  window.addEventListener("resize", updateSwiperConfig);
	
  function handleBannerButtonClick() {
    removeActiveSlide(bannersSwiper);
  }

  const closeButtons = document.querySelectorAll(".home_banner-close");

  closeButtons.forEach((button) => {
    button.addEventListener("click", handleBannerButtonClick);
  });

  function removeActiveSlide(swiper) {
    if (swiper) {
      const activeIndex = swiper.activeIndex;

      if (activeIndex !== undefined) {
        swiper.removeSlide(activeIndex);
        swiper.update();
      } else {
        console.error("No active slide found");
      }
    } else {
      console.error("Invalid swiper instance");
    }
  }
});
</script></body></html>