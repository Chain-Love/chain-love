#onetrust-consent-sdk {
  font-family: "proxima-nova";
}

#onetrust-banner-sdk {
  max-width: max-content;
  max-width: 1198px !important;
  overflow: hidden;
  margin: auto;
  padding: 16px;
  border: 1px solid #141c29;
  outline: none !important;
  background-color: #090d14 !important;
  border-radius: 40px 40px 0 0;
  box-shadow: 0 -2px 16px #141c2966 !important;
}

#onetrust-banner-sdk * {
  outline: none !important;
  color: #f7f8fc !important;
  font-size: 12px !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk #ot-pc-content *,
#onetrust-consent-sdk #onetrust-pc-sdk #ot-pc-lst * {
  color: #f7f8fc !important;
}

/* Hack on the Topper logo on the Preference center */
/*#onetrust-consent-sdk #onetrust-pc-sdk .ot-pc-logo img {
  display: none;
}*/

/*#onetrust-consent-sdk #onetrust-pc-sdk .ot-pc-logo {
  background-image: url("../../media/images/logo-light.svg");
}*/

#onetrust-banner-sdk .ot-sdk-container,
#onetrust-pc-sdk .ot-sdk-container,
#ot-sdk-cookie-policy .ot-sdk-container {
  width: 100% !important;
}

#onetrust-banner-sdk #onetrust-button-group * {
  position: relative !important;
  width: 100%;
  overflow: hidden !important;
  margin: 0 !important;
  padding: 16px !important;
  display: block !important;
  border-color: transparent !important;
  border-radius: 88px !important;
  font-size: 16px !important;
  font-weight: 400 !important;
  text-decoration: none !important;
  text-align: center !important;
  line-height: 28px !important;
  white-space: nowrap !important;
  cursor: pointer !important;
  transition: background-color 0.3s;
}

#onetrust-consent-sdk #onetrust-pc-sdk .save-preference-btn-handler button.onetrust-close-btn-handler .ot-pc-footer,
#onetrust-consent-sdk #onetrust-pc-sdk #ot-pc-content #accept-recommended-btn-handler {
  color: #141c29 !important;
}

#onetrust-consent-sdk #onetrust-group-container #onetrust-policy {
  margin: 16px 0 7px 0 !important;
}

/* Add margin to title in smaller screens */
#onetrust-consent-sdk #onetrust-group-container #onetrust-policy #onetrust-policy-title {
  display: block;
}

#onetrust-consent-sdk #onetrust-group-container #onetrust-policy .ot-dpd-title {
  margin-top: 16px;
  margin-bottom: 6px;

}

/* New button color */
#onetrust-consent-sdk #onetrust-banner-sdk #onetrust-accept-btn-handler,
#onetrust-consent-sdk #onetrust-banner-sdk #onetrust-reject-all-handler,
#onetrust-consent-sdk #onetrust-banner-sdk #onetrust-pc-btn-handler {
  min-width: 0 !important;
  margin: 4px 0 !important;
  padding: 8px 4px !important;
  font-size: 12px !important;
}

#onetrust-consent-sdk #onetrust-button-group #onetrust-reject-all-handler {
  border: 1px solid #84fb7f !important;
  opacity: 1 !important;
  background-color: transparent !important;
  color: #84fb7f !important;
  transition: background-color 0.3s;
}

#onetrust-consent-sdk #onetrust-button-group #onetrust-reject-all-handler:hover,
#onetrust-consent-sdk #onetrust-button-group #onetrust-reject-all-handler:focus {
  background-color: rgba(132, 251, 127, 0.08) !important;
}

/* Accept Cookies button */
#onetrust-consent-sdk #onetrust-accept-btn-handler,
#onetrust-consent-sdk button.save-preference-btn-handler.onetrust-close-btn-handler,
#onetrust-consent-sdk button#accept-recommended-btn-handler {
  border: none !important;
  opacity: 1 !important;
  background-color: #84fb7f !important;
  color: #141c29 !important;
  transition: background-color 0.3s;
}

/* added the options for :focus-visible for both "Accept cookies" and "Manage Settings" buttons */
#onetrust-consent-sdk #onetrust-pc-btn-handler:focus-visible,
#onetrust-consent-sdk button.ot-pc-refuse-all-handler:focus-visible,
#onetrust-consent-sdk #onetrust-accept-btn-handler:focus-visible,
#onetrust-consent-sdk button.save-preference-btn-handler.onetrust-close-btn-handler:focus-visible,
#onetrust-consent-sdk button#accept-recommended-btn-handler:focus-visible,
#onetrust-consent-sdk #onetrust-accept-btn-handler:hover,
#onetrust-consent-sdk button.save-preference-btn-handler.onetrust-close-btn-handler:hover,
#onetrust-consent-sdk button#accept-recommended-btn-handler:hover {
  border: none !important;
  opacity: 1 !important;
  background-color: #62e75f !important;
  color: #001f02 !important;
}

#onetrust-consent-sdk #onetrust-pc-btn-handler {
  border: none !important;
  background-color: #090d14 !important;
}

/* Refuse Cookies button */
#onetrust-consent-sdk button.ot-pc-refuse-all-handler {
  border: none !important;
  background-color: transparent !important;
  color: #f7f8fc !important;
  transition: background-color 0.3s;
}

#onetrust-consent-sdk #onetrust-pc-btn-handler:hover,
#onetrust-consent-sdk button.ot-pc-refuse-all-handler:hover,
#onetrust-consent-sdk button.ot-link-btn .ot-pgph-link .ot-pgph-link-subgroup:hover {
  opacity: 1 !important;
  background-color: #62e75f !important;
  color: #141c29 !important;
}

#onetrust-consent-sdk .ot-link-btn {
  text-decoration: underline !important;
  transition: color 0.3s !important;
}

/* List of Partners */
#onetrust-consent-sdk .ot-link-btn:hover {
  color: #62e75f !important;
}

#onetrust-consent-sdk #onetrust-close-btn-container {
  filter: brightness(0) invert(1);
}

#onetrust-consent-sdk .ot-floating-button__close {
  display: flex;
  justify-content: center;
  align-items: center;
}

@media (min-width: 550px) {
  #onetrust-consent-sdk .ot-sdk-columns {
    margin-left: 0 !important;
  }
}

#onetrust-consent-sdk #onetrust-button-group {
  display: flex !important;
  flex-direction: row;
  gap: 12px;
}

#onetrust-consent-sdk #onetrust-pc-sdk {
  top: 50%;
  right: auto;
  bottom: auto;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #141c29 !important;
  border-radius: 28px !important;
  box-shadow: none;
}

#onetrust-consent-sdk .ot-sdk-container {
  margin: 0 !important;
  padding: 0 !important;
}

/* "We care about your Privacy" */
/* #onetrust-consent-sdk h2#onetrust-policy-title */
#onetrust-consent-sdk #onetrust-pc-sdk #ot-lst-title h3 {
  color: #f7f8fc !important;
}

#onetrust-consent-sdk h2#onetrust-policy-title,
#onetrust-consent-sdk #onetrust-group-container #onetrust-policy h3.ot-dpd-title {
  margin: 12px 0 !important;
  line-height: 15px !important;
}

#onetrust-consent-sdk #accept-recommended-btn-handler {
  outline: none !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-tgl .ot-switch .ot-switch-nob {
  border: 1px solid rgba(115, 132, 176, 0.1) !important;
  background-color: rgba(115, 132, 176, 0.1) !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-tgl input:focus + .ot-switch {
  outline: none;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-tgl .ot-switch .ot-switch-nob:hover {
  background-color: rgba(115, 132, 176, 0.2) !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-tgl .ot-switch .ot-switch-nob::before {
  content: "";
  background-color: #f7f8fc !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-tgl input:checked + .ot-switch .ot-switch-nob::before {
  content: "";
  background-color: #001f02 !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-tgl input:checked + .ot-switch .ot-switch-nob {
  border: 1px solid #84fb7f !important;
  background-color: #84fb7f !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-tgl input:checked + .ot-switch .ot-switch-nob:hover {
  border: 1px solid #62e75f !important;
  background-color: #62e75f !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-chkbox input:checked ~ label::before {
  border: 1px solid #62e75f !important;
  background-color: #62e75f !important;
}

#onetrust-consent-sdk button#filter-btn-handler {
  background-color: #84fb7f !important;
}

#onetrust-consent-sdk #onetrust-consent-sdk #onetrust-pc-sdk .ot-ven-link,
#onetrust-consent-sdk #onetrust-pc-sdk .ot-cat-grp .ot-always-active,
#onetrust-consent-sdk #onetrust-consent-sdk #onetrust-pc-sdk .category-vendors-list-handler,
#onetrust-consent-sdk #onetrust-consent-sdk #onetrust-pc-sdk .category-vendors-list-handler + a {
  color: #141c29 !important;
}

#onetrust-consent-sdk .ot-dpd-container {
  border-left: none !important;
}

/* Override default media query style */
@media only screen and (max-width: 400px) {
  #onetrust-banner-sdk .ot-sdk-container,
  #onetrust-pc-sdk .ot-sdk-container,
  #ot-sdk-cookie-policy .ot-sdk-container {
    width: 100% !important;
  }
}

@media only screen and (min-width: 550px) {
  /* original rule */
  #onetrust-consent-sdk .ot-sdk-container {
    width: 90% !important;
    margin: 0 auto !important;
  }

  #onetrust-consent-sdk #onetrust-group-container #onetrust-policy {
    margin: 36px 0 7.5px 0 !important;
  }

  /* #onetrust-consent-sdk #onetrust-group-container #onetrust-policy #onetrust-policy-title {
    display: inline !important;
  } */

  #onetrust-consent-sdk #onetrust-banner-sdk #onetrust-accept-btn-handler,
  #onetrust-consent-sdk #onetrust-banner-sdk #onetrust-reject-all-handler,
  #onetrust-consent-sdk #onetrust-banner-sdk #onetrust-pc-btn-handler {
    min-width: 125px !important;
    margin: 0 !important;
    padding: 16px !important;
    font-size: initial !important;
  }

  #onetrust-consent-sdk #onetrust-button-group {
    gap: 20px !important;
  }
}

/* buttons go the right side on >896px */
@media only screen and (min-width: 896px) {
  #onetrust-consent-sdk #onetrust-button-group {
    min-width: 160px;
    margin: 0 0 0 12px;
    flex-direction: column;
    align-items: center;
  }
}

/* Text get splits into 2 columns */
@media only screen and (min-width: 1024px) {
  #onetrust-consent-sdk.ot-iab-2 .ot-dpd-container {
    padding: 16px 16px 12px 0 !important;
  }

  #onetrust-consent-sdk #onetrust-policy-text {
    padding: 0 16px 12px 0 !important;
  }

  #onetrust-consent-sdk .ot-sdk-ten.ot-sdk-columns {
    width: 82.7% !important;
  }

  #onetrust-consent-sdk h2#onetrust-policy-title,
  #onetrust-consent-sdk #onetrust-group-container #onetrust-policy h3.ot-dpd-title {
    margin: 0;
  }
}

/* Increases Font size on buttons on Preference Center */
#onetrust-consent-sdk .ot-pc-footer,
#onetrust-consent-sdk #accept-recommended-btn-handler {
  color: #f7f8fc !important;
  font-size: 12px !important;
}

/* Hides "cookie widget" that opens settings menu */
/*#onetrust-consent-sdk #ot-sdk-btn-floating {
  position: absolute;
  width: 0 !important;
  height: 0 !important;
  overflow: hidden;
  opacity: 0 !important;
  pointer-events: none !important;
  transition: none !important;
}*/

.ot-floating-button__close {
  align-items: center;
  display: flex;
  justify-content: center;
}

#ot-sdk-btn-floating .ot-floating-button__back {
  background-color: #141c29 !important;
}

#ot-sdk-btn-floating .ot-floating-button__back svg {
  margin: auto;
}

#ot-sdk-btn-floating .ot-floating-button__front {
	background-color: transparent !important;
}

#onetrust-pc-sdk .ot-pc-header,
#onetrust-pc-sdk .ot-pc-footer {
  border-color: #273149 !important;
}

#onetrust-banner-sdk .ot-sdk-button,
#onetrust-banner-sdk button,
#onetrust-pc-sdk .ot-sdk-button,
#onetrust-pc-sdk button,
#ot-sdk-cookie-policy .ot-sdk-button,
#ot-sdk-cookie-policy button,
#onetrust-consent-sdk button#accept-recommended-btn-handler:focus {
  border: none !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk .ot-acc-grpcntr.ot-acc-txt,
#onetrust-consent-sdk #onetrust-pc-sdk .ot-acc-grpcntr.ot-acc-txt .ot-pgph-desc
#onetrust-consent-sdk #onetrust-pc-sdk .ot-acc-txt .ot-subgrp-tgl .ot-switch.ot-toggle,
#ot-ven-lst .ot-ven-item .ot-ven-dets {
  border-color: #273149 !important;
  background-color: #141c29 !important;
}

#ot-ven-lst {
  border: none !important;
}

/* Consents list */
#onetrust-pc-sdk .ot-accordion-layout.ot-cat-item,
#onetrust-pc-sdk .ot-ven-dets .ot-ven-pur h4,
#onetrust-consent-sdk #onetrust-pc-sdk .ot-subgrp-cntr {
  border-color: #273149 !important;
}

/* List of Vendors */
#onetrust-consent-sdk #onetrust-pc-sdk .ot-search-cntr input {
  border-color: rgba(255, 255, 255, 0);
  background-color: #273149 !important;
  color: #f7f8fc;
}

#onetrust-consent-sdk #onetrust-pc-sdk #ot-sel-blk {
  border-bottom: 1px solid #273149;
  background-color: #141c29 !important;
}

#onetrust-consent-sdk #onetrust-pc-sdk #ot-ven-lst .ot-ven-item {
  border-color: #1d2738 !important;
}

/* Standardise hover effect on button and anchors */
#onetrust-consent-sdk #onetrust-policy-text a:hover,
#onetrust-consent-sdk #ot-pc-lst .ot-ven-box:hover,
#onetrust-consent-sdk #onetrust-pc-sdk  #ot-pc-content a:hover,
#onetrust-consent-sdk #onetrust-pc-sdk #ot-pc-lst a:hover,
#onetrust-consent-sdk #onetrust-pc-sdk #ot-pc-lst button:hover,
#onetrust-consent-sdk #onetrust-pc-sdk #ot-pc-content .ot-vlst-cntr button:hover,
#onetrust-consent-sdk #onetrust-pc-sdk .ot-pgph-link:hover,
#onetrust-consent-sdk #onetrust-pc-sdk .ot-acc-grpcntr.ot-acc-txt a:hover {
  color: #62e75f !important;
  text-decoration: underline !important;
  transition: color 0.3s;
}
</style></div><div class="hide"><div id="w-node-adbfdc05-5854-d71b-9d53-a4a2ec433d2f-ec433cda" class="loading-spinner w-embed"><style>
  svg .loader-ring {
    transform-origin: 50px 50px;
    animation: starting-fill 0.5s forwards,
      vary-loader-width 3s 0.5s linear infinite alternate,
      spin 1.6s 0.2s linear infinite;
  }
  svg .loader-ring-overlay {
    visibility: hidden;
    transform-origin: 50px 50px;
    animation: spin 1.6s 0.2s linear infinite;
  }
  .complete .loader-ring-overlay {
    visibility: visible;
    animation: complete-fill 0.5s linear forwards,
      spin 1.6s 0.2s linear infinite;
  }
  .complete .loader-ring {
    animation: starting-fill 0.5s forwards,
      vary-loader-width 3s 0.5s linear infinite alternate,
      spin 1.6s 0.2s linear infinite, fade 0.1 0.5s linear forwards;
  }
  .complete svg {
    animation: fade 0.2s 0.7s linear forwards;
    transition: all 0s 0.9s;
    cursor: initial;
    pointer-events: none;
  }

  @keyframes starting-fill {
    to {
      stroke-dashoffset: 270;
    }
  }
  @keyframes vary-loader-width {
    0% {
      stroke-dashoffset: 270;
    }
    50% {
      stroke-dashoffset: 170;
    }
    100% {
      stroke-dashoffset: 275;
    }
  }
  @keyframes complete-fill {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes fade {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

